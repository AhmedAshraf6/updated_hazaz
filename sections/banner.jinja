<section class="py-3 banner-img lazy-banner" 
    section-id="{{ sectionId }}"
    data-lg-scroll-offset="130"
    data-md-scroll-offset="130"
    data-sm-scroll-offset="94"   
>
    <div class="{% if settings.container_type == 'container' %} layout {% endif %}">
        <div class='flex my-5 sm:my-10 relative z-[1]  {% if settings.container_type == "no-container" %} m-0 {% endif %}'>
                <a aria-label="banner url" href="{{ settings.url }}" style="z-index: 9" class="w-full flex-1"> 
                    <div class="relative aspect-video skeleton-parent">  
                        <div class="skeleton skBanner w-full h-full absolute"></div>           
                        {% if settings.image %}
                            <img class=" hidden lg:block  w-full h-auto object-contain md:object-cover rounded-3xl lazy" alt="ads banner"
                            onload="this.closest('.relative').querySelector('.skeleton')?.remove();this.closest('.skeleton-parent').classList.remove('aspect-video')"
                            data-src="{{ image_url(settings.image, w=1700, f='auto') }}"
                            data-srcset="{{ image_url(settings.image, w=750, f='auto') }} 750w, {{ image_url(settings.image, w=960, f='auto') }} 960w, {{ image_url(settings.image, w=1700, f='auto') }} 1700w"
                            sizes="100vw"
                            />
                        {% endif %}
                        {% if settings.image_mobile %}
                            <img loading="lazy" class=" block lg:hidden w-full h-auto object-contain md:object-cover  rounded-3xl lazy" alt="ads banner"
                              onload="this.closest('.relative').querySelector('.skeleton')?.remove();this.closest('.skeleton-parent').classList.remove('aspect-video')"
                            data-src="{{ image_url(settings.image_mobile, w=750, f='auto') }}"
                            data-srcset="{{ image_url(settings.image_mobile, w=400, f='auto') }} 400w, {{ image_url(settings.image_mobile, w=640, f='auto') }} 640w, {{ image_url(settings.image_mobile, w=750, f='auto') }} 750w"
                            sizes="100vw"
                            />
                        {% else %}
                            <img class=" block lg:hidden w-full h-auto object-contain md:object-cover  rounded-3xl lazy" alt="ads banner"
                           onload="this.closest('.relative').querySelector('.skeleton')?.remove();this.closest('.skeleton-parent').classList.remove('aspect-video')"
                            data-src="{{ image_url(settings.image, w=750, f='auto') }}"
                            data-srcset="{{ image_url(settings.image, w=400, f='auto') }} 400w, {{ image_url(settings.image, w=640, f='auto') }} 640w, {{ image_url(settings.image, w=750, f='auto') }} 750w"
                            sizes="100vw"
                            />
                        {% endif %}  
                    </div>
                </a>
        </div>        
    </div>
</section>
<script>


</script>