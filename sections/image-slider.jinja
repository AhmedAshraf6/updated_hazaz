
<section section-id="{{ sectionId }}" class="image_slider  text-base-content my-5 lg:my-8">
    <div class="section_one">
      <div class="layout grid grid-cols-1 sm:grid-cols-2">
        <div class="flex bg-base-200 pt-10">
          <div class="flex-1 self-end">
          <img src="{{ settings.section_one_image }}" alt="{{ settings.section_one_title }}" class="w-full h-auto object-cover">
          </div>      
          <div class="flex-1 flex flex-col gap-3 sm:gap-5">
            <h4 class="text-lg sm:text-xl font-bold">{{ settings.section_one_title }}</h4>
            <p class="text-xs leading-4 sm:leading-6">{{ settings.section_one_description }}</p>
            {% if settings.section_one_btn_text %}
                <a href="{{ settings.section_one_btn_url }}" class="btn btn-primary self-start">{{ settings.section_one_btn_text }}</a>
            {% endif %}
            
          </div>      
        </div>
        {# products #}
        <div class="py-10 ps-5">
          <div class="swiper home_image_silder">
              <div class="swiper-wrapper">
                    {% for key,item in settings.section_one_products %}
                        <div class="swiper-slide flex flex-col h-full">
                          {% set product = item.product %}{% set index = key %}
                          {% include 'components/product-card.jinja' %}
                        </div>
                    {% endfor %}
              </div>
        
          </div>
        </div>
      </div>
    </div>
    
    <div class="section_two">
      <div class="layout grid grid-cols-1 sm:grid-cols-2">
          {# products #}
        <div class="py-10 ps-5">
          <div class="swiper home_image_silder_two">
              <div class="swiper-wrapper">
                    {% for key,item in settings.section_two_products %}
                        <div class="swiper-slide flex flex-col h-full">
                          {% set product = item.product %}{% set index = key %}
                          {% include 'components/product-card.jinja' %}
                        </div>
                    {% endfor %}
              </div>
        
          </div>
        </div>
        <div class="flex bg-base-200 pt-10">
          <div class="flex-1 self-end">
          <img src="{{ settings.section_two_image }}" alt="{{ settings.section_two_title }}" class="w-full h-auto object-cover">
          </div>      
          <div class="flex-1 flex flex-col gap-3 sm:gap-5">
            <h4 class="text-lg sm:text-xl font-bold">{{ settings.section_two_title }}</h4>
            <p class="text-xs leading-4 sm:leading-6">{{ settings.section_two_description }}</p>
            {% if  settings.section_two_btn_text %}
            
              <a href="{{ settings.section_two_btn_url }}" class="btn btn-primary self-start">{{ settings.section_two_btn_text }}</a>
            {% endif %}
            
          </div>      
        </div>
    
      </div>
    </div>
    
</section>
<script>
 document.addEventListener('DOMContentLoaded', () => {
   
        
        let swiperImageSldier = new Swiper('.home_image_silder', {
            slidesPerView:1,
            spaceBetween: 30,
            loop: true,
            breakpoints: {
                  640: {
                  slidesPerView: 2,
                  spaceBetween: 20,
                }
             }
          }); 
        let swiperImageSldier2 = new Swiper('.home_image_silder_two', {
            slidesPerView:1,
            spaceBetween: 30,
            loop: true,
            breakpoints: {
                  640: {
                  slidesPerView: 2,
                  spaceBetween: 20,
                }
             }
          }); 
                  
  });
</script>