              </a>
  
       {% endif %}
    </div>

    {% vitrin_body %}
    {% block footer_scripts %}{% endblock %}
    <script defer src="{{ 'app2.js?v=3.00' | asset_url }}"></script>  
    <script defer  src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.js"></script>

    <script>
     window.appDirection = '{% if session.lang.code == 'ar' %}rtl{% else %}ltr{% endif %}';
  // hide default olyality points
    function makeFunctionHead() {
        const targetElement = document.querySelector('.loyalty_button_footer');
        if (targetElement) {
            targetElement.style.display = 'none';
            observer.disconnect();
        }
   
   }

    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (mutation.type === 'childList') {
                makeFunctionHead();
            }
        });
    });

    observer.observe(document.body, {
        childList: true,   
        subtree: true, 
    });

    makeFunctionHead();
    

     const localsLayout = {
        success_add_cart: "{{ _("Product successfully added to the cart") }}",
        error:"{{ _("An error occurred, please try again") }}",
        product_out_of_stock:"{{ _("Out of Stock") }}",
        add_to_cart_2:"{{ _("Add to Cart") }}",
        delete_promo_success:"{{  _("Coupon deleted successfully") }}",
        free_shipping: "{{  _("Congratulations! Enjoy free shipping") }}",
        remaining: "{{  _("Remaining") }}",
        free_ship: "{{  _("for free shipping") }}",
        empty_fields: "{{  _("Please fill in all fields") }}",

        
     }
      const  store = {{ store | tojson }};


 
      

  
    </script>
  
</body>
</html>
