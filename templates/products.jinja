{% extends "layout.jinja" %}

{% block title %} {{ store.name }} - {{ _("All Products") }} {% endblock %}

{% block header %} {{ include('header.jinja') }} {% endblock %}

{% block top_links %}
{% endblock %}


{% block main_content %}
     
     {% set breadcrumbs = [
                    { label: _("Home"), url: '/' },
                    { label: _("All Products") }
                ] %}
     {% include 'components/breadcrumbs.jinja' %}

    {% if settings.banners_banner_products_page_image %}
       {% set image = settings.banners_banner_products_page_image %}
       {% include 'components/shared_banner.jinja' %}
    {% endif %}
    
   {% if products.data|length > 0 %}
        <div class="my-5 layout allProductsPage">
            
            <div class="grid grid-cols-3 lg:grid-cols-4 gap-4">

                    <div class="col-span-3 block lg:hidden">
                        <div class="drawer drawer-end ">
                            <input id="my-drawer-4" type="checkbox" class="drawer-toggle" />
                            <div class="drawer-content">
                                <!-- Page content here -->
                                <label for="my-drawer-4" class="drawer-button btn btn-primary btn-sm">
                                    <svg width="19" height="24" viewBox="0 0 19 24"  fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <g clip-path="url(#clip0_312_51187)">
                                            <path d="M0.655273 17.0273H6.64358V18.9922H0.655273V17.0273ZM0.655273 5.05069H10.6202V7.0156H0.655273V5.05069ZM10.6202 21.0039H8.65527V15.0156H10.6202V17.0273H18.6202V18.9922H10.6202V21.0039ZM4.63188 9.0273H6.64358V15.0156H4.63188V13.0039H0.655273V11.039H4.63188V9.0273ZM18.6202 13.0039H8.65527V11.039H18.6202V13.0039ZM12.6319 9.0273V3.03899H14.6436V5.05069H18.6202V7.0156H14.6436V9.0273H12.6319Z" fill="{{ store.settings.branding.colors.on_primary }}"></path>
                                            </g>
                                            <defs>
                                            <clipPath id="clip0_312_51187">
                                            <rect width="18" height="24" fill="white" transform="matrix(1 0 0 -1 0.637695 24)"></rect>
                                            </clipPath>
                                            </defs>
                                        </svg>
                                        <span class="text-base sm:text-lg">{{ _("Filter By") }}</span>
                                </label>
                            </div>
                            <div class="drawer-side z-[2]">
                                <label for="my-drawer-4" aria-label="close sidebar" class="drawer-overlay"></label>
                                <ul class="menu bg-base-200 text-base-content min-h-full w-80 p-4">
                                {% set index = key %}
                                {% include "components/products_filter.jinja" %}
                                </ul>
                            </div>
                        </div>
                    </div>
                
                    {# filter section #}
                    <div class="col-span-1 hidden lg:block">
                    <div class="hidden">
                        {% set async=true %} {% include 'vitrin:products/filters.jinja' %}
                    </div>
                    <div class="flex flex-col gap-3 py-5 px-3 bg-base-200 min-h-[500px] rounded-3xl sticky top-[100px]">
                        {% set index = key %}
                        {% include "components/products_filter.jinja" %}
                    </div>
                    </div>

                    {# all products #}
                    <div class="col-span-3">
                        <div id="products-list" class="custom_products_list w-100 grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-3">
                            {% for product in products.data %}
                                  
                                  {% if product.is_infinite == true or product.quantity > 0 %}
                                      {% set index = key %}
                                      {% include 'components/product-card.jinja' %}
                                {% endif %}
                            {% endfor %}    
                        </div>
                        <div class="loading_more_products flex justify-center mb-4  w-100">
                            <svg width="28" height="28" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="stroke-primary">
                                    <path d="M30 5V15" stroke="#DCA54C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M30 45V55" stroke="#DCA54C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M12.3252 12.325L19.4002 19.4" stroke="#DCA54C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M40.6001 40.6001L47.6751 47.6751" stroke="#DCA54C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M5 30H15" stroke="#DCA54C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M45 30H55" stroke="#DCA54C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M12.3252 47.6751L19.4002 40.6001" stroke="#DCA54C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M40.6001 19.4L47.6751 12.325" stroke="#DCA54C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>

                        </div>
                        <p class="d-flex justify-content-center my-4 text-center fs-4 noMoreProducts hidden">{{ _("No more products") }}</p>
                    </div>

                </div>
            
            
        </div>
   {% else %}
        <div class="flex flex-col items-center justify-center gap-5">  
              <div class="w-full max-w-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" viewBox="0 0 751.13137 526.91128" xmlns:xlink="http://www.w3.org/1999/xlink" role="img" artist="Katerina Limpitsouni" source="https://undraw.co/"><path d="M803.9793,711.53349l.01521-.697a80.52863,80.52863,0,0,1,30.11215-60.64309A78.1326,78.1326,0,0,1,850.89289,640.078l.572-.25474.09758.61813c1.16152,7.38021,3.0009,14.91289,3.85784,18.25612l5.74415-22.41411.63823-.18436a15.27246,15.27246,0,0,1,16.303,5.20878,15.53409,15.53409,0,0,1,1.61173,17.33177c-1.33891,2.49455-2.655,5.09733-3.9282,7.61426-4.37385,8.64929-8.89655,17.59309-15.48708,24.54163A48.6753,48.6753,0,0,1,821.043,705.4408Z" transform="translate(-224.09411 -186.28663)" fill="#f2f2f2"/><path d="M629.34213,506.85309H481.06067A20.13792,20.13792,0,0,1,460.94553,486.738V278.13886a91.956,91.956,0,0,1,91.85189-91.85223h76.54505a20.13755,20.13755,0,0,1,20.1148,20.1148V486.738A20.1377,20.1377,0,0,1,629.34213,506.85309Z" transform="translate(-224.09411 -186.28663)" fill="#f2f2f2"/><path d="M486.24565,367.57055a8.4817,8.4817,0,0,0-8.472,8.472v47.61288a8.482,8.482,0,0,0,8.472,8.47232H630.34756a8.482,8.482,0,0,0,8.472-8.47232V376.04253a8.4817,8.4817,0,0,0-8.472-8.472Z" transform="translate(-224.09411 -186.28663)" fill="#fff"/><path d="M630.6943,336.68029H486.59273a9.17633,9.17633,0,0,1-9.16614-9.16614A56.84375,56.84375,0,0,1,534.206,270.73479h96.48868a9.17632,9.17632,0,0,1,9.16614,9.16614v47.61288A9.17691,9.17691,0,0,1,630.6943,336.68029Z" transform="translate(-224.09411 -186.28663)" fill="#fff"/><path d="M692.73619,424.823H526.852a3.68184,3.68184,0,0,1-3.67764-3.67763V377.43719a3.68172,3.68172,0,0,1,3.67764-3.6775H692.73619a3.68172,3.68172,0,0,1,3.67763,3.6775v43.70819A3.68184,3.68184,0,0,1,692.73619,424.823Z" transform="translate(-224.09411 -186.28663)" fill="#fff"/><path d="M692.73635,425.51721H526.852a4.37667,4.37667,0,0,1-4.37173-4.37173V377.43726a4.37668,4.37668,0,0,1,4.37173-4.37174H692.73635a4.37669,4.37669,0,0,1,4.37174,4.37174v43.70822A