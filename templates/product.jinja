                particle.style.left = `${left}%`;
                particle.style.bottom = '0';
                particle.style.animationDelay = `${delay}s`;

                // ألوان متنوعة للجسيمات
                const colors = ['#fff176', '#ffeb3b', '#ffc700', '#ff8f00'];
                particle.style.backgroundColor =
                    colors[Math.floor(Math.random() * colors.length)];

                particlesContainer.appendChild(particle);
                }
            }

            // دالة العد مع تأثير ارتداد
            function countUp(target, el) {
                const duration = 1500;
                const start = performance.now();
                const startCount = currentCount;

                // إضافة تأثير الارتداد
                el.classList.add('bounce');
                setTimeout(() => el.classList.remove('bounce'), 600);

                // إضافة تأثير التمييز
                el.parentElement.parentElement.parentElement.classList.add('highlight');
                setTimeout(
                () =>
                    el.parentElement.parentElement.parentElement.classList.remove(
                    'highlight'
                    ),
                800
                );

                requestAnimationFrame(function step(ts) {
                const t = Math.min(1, (ts - start) / duration);
                // استخدام easeOutBack للارتداد
                const easedT = 1 - Math.pow(1 - t, 3);
                currentCount = Math.floor(
                    startCount + easedT * (target - startCount)
                );
                el.textContent = currentCount;

                // تحديث شريط التقدم
                const progress = (currentCount / 100) * 100;
                bar.style.width = `${progress}%`;
                progressPercentage.textContent = `${Math.round(progress)}%`;

                if (t < 1) {
                    requestAnimationFrame(step);
                } else {
                    currentCount = target;
                    el.textContent = target;
                    createParticles(); // إنشاء الجسيمات عند اكتمال العد
                }
                });
            }

            // تحديث العدد
            function updateCount() {
                const randomCount = Math.floor(Math.random() * 81) + 20; // رقم بين 20 و100
                countUp(randomCount, countEl);

                // إعادة تعيين العد التنازلي
                countdown = 5;
            }

            // بدء التحديث التلقائي
            function startAutoUpdate() {
                // تحديث فوري أول
                updateCount();

                // بدء الموقت للتحديثات التالية
                updateInterval = setInterval(updateCount, 5000);

                // بدء العد التنازلي
                countdownInterval = setInterval(() => {
                countdown--;

                if (countdown <= 0) {
                    countdown = 5;
                }
                }, 1000);
            }

        // Build variant buttons immediately (before DOMContentLoaded) so active styling is visible instantly
        handleVariations();

        document.addEventListener('DOMContentLoaded', function () {
            initializeSliderProduct();
            handleZidCustomInputFields();
            setTimeout(() => {
            startAutoUpdate();
            }, 1000);

            // إنشاء الجسيمات الأولية
            createParticles();

            if(product.purchase_restrictions.sale_price_period_end){
                startCountdown(product.purchase_restrictions.sale_price_period_end);
            }
            const lightbox = GLightbox({
              selector: '.glightbox',
              zoomable: true,
              openEffect:'fade',	
              closeEffect:'fade',
                 

	
            });
            const lightbox2 = GLightbox({
              selector: '.glightbox10',
                touchNavigation: true,
                touchFollowAxis: false,
                closeOnOutsideClick: true,
            
            });
           document.addEventListener('click', function (e) {
                    // Check if clicked element is the overlay (works even if recreated)
                    if (e.target.classList.contains('ginner-container')) {
                                        lightbox.close();
                                        lightbox2.close();

                    }
            });
            
     });
        
    </script>
{% endblock %}

