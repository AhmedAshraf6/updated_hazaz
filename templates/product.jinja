        async function changeQuantity(delta) {
    const input = document.getElementById('qunatityInputProduct_single_page');
    const currentValue = parseInt(input.value, 10) || 0;
    const minValue = parseInt(input.getAttribute('min'), 10) || 1;
    const maxValue = parseInt(input.getAttribute('max'), 10) || Infinity;

    // Calculate new value
    let newValue = currentValue + delta;
    
    // Enforce min and max limits
    if (newValue > maxValue) {
        newValue = maxValue;
    }
    if (newValue < minValue) {
        newValue = minValue;
        return;
    }
    
    input.value = newValue;

    // Prepare update based on delta
    if (delta === 1) {
        // Increment - just add 1
        await updateProductSinglePage(1);
    } else if (delta === -1) {
        // Decrement - need to check current cart
        try {
            const cartResponse = await zid.cart.get({ showErrorNotification: true });
            const realPrID = product.id.replace(/-/g, '');
            if (!cartResponse) return;
            const productInCart = cartResponse.products.find(p => p.product_id == realPrID);

        
            deleteProductInsidePage(productInCart.id);
            updateProductSinglePage(newValue);
           
        } catch (error) {
            console.error('Cart update error:', error);
        }
    }
}

