{% extends "layout.jinja" %}
{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block title %} 
    {% if product.seo.title %}
        {{ product.seo.title| safe }}
    {% else %}
        {{ store.name }} - {{ product.name| safe }}
    {% endif %}
{% endblock %}





{% block main_content %}

    {% set breadcrumbs = [
                    { label: _("Home"), url: '/' },
                    { label: _("Products"),url: '/products' },
                    { label: product.name },
                ] %}
    {% include 'components/breadcrumbs.jinja' %}

    {% if settings.banners_banner_cart_page_image %}
       {% set image = settings.banners_banner_product_page_image %}
       {% include 'components/shared_banner.jinja' %}
    {% endif %}
   
    <div class="my-5 layout product_page inshalla24">
      <div class="grid grid-cols-1 sm:grid-cols-6 gap-5 sm:gap-10">
            <div class="flex flex-col gap-6 sm:gap-8 sm:col-span-3">

                {# first option #}
              <div class=" product-images-box {% if product.selected_product.media | length <= 0 %}hidden{% endif %}">

                    <!-- Main Swiper -->
                    <div class=" swiper mySwiperProdyct2 w-full h-[80%]">
                        <div class="swiper-wrapper swiperWrapper2">
                            {% for media in product.selected_product.media %}

                                {% if media.provider == 'youtube' %}
                                    {# استخراج ID الفيديو من لينك YouTube #}
                                    {% if 'watch?v=' in media.link %}
                                        {% set video_id = media.link | split('watch?v=') | last %}
                                    {% elif 'youtu.be/' in media.link %}
                                        {% set video_id = media.link | split('youtu.be/') | last %}
                                    {% elif 'shorts/' in media.link %}
                                        {% set video_id = media.link | split('shorts/') | last %}
                                    {% else %}
                                        {% set video_id = '' %}
                                    {% endif %}

                                    {% if loop.first %}
                                        <div class="col-span-2 row-span-2">
                                            <iframe 
                                                src="https://www.youtube.com/embed/{{ video_id }}" 
                                                title="YouTube video player"
                                                frameborder="0"
                                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                allowfullscreen
                                                class="w-full h-[500px]"
                                            ></iframe>
                                        </div>
                                    {% else %}
                                        <div class="swiper-slide">
                                            <iframe 
                                                src="https://www.youtube.com/embed/{{ video_id }}" 
                                                title="YouTube video player"
                                                frameborder="0"
                                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                allowfullscreen
                                                class="w-full h-full"
                                            ></iframe>
                                        </div>
                                    {% endif %}

                                {% else %}
                                    <div class="swiper-slide">
                                            <img
                                                src="{{ image_url(media.image.full_size, w=960, f='auto') }}"
                                                srcset="{{ image_url(media.image.full_size, w=400, f='auto') }} 400w, {{ image_url(media.image.full_size, w=640, f='auto') }} 640w, {{ image_url(media.image.full_size, w=960, f='auto') }} 960w"
                                                sizes="(max-width: 640px) 100vw, 50vw"
                                                width="960" height="960"
                                                alt="{{ media.image.alt }}"
                                                data-gallery="gallery1"
                                                class="block w-full h-full object-[unset] sm:object-contain glightbox"
                                                {% if loop.first %}fetchpriority="high"{% endif %}
                                            >
                                    </div>
                                {% endif %}

                            {% endfor %}
                        </div>

                        <!-- Navigation -->
                        <div class="swiper-button-next"></div>
                        <div class="swiper-button-prev"></div>
                    </div>

                    <!-- Spacer -->
                    <div class="h-[2%] line-space"></div>

                <!-- Thumbnail Swiper -->
                <div thumbsSlider="" class="swiper mySwiperProduct w-full h-[18%]">
                    <div class="swiper-wrapper swiperWrapper">
                        {% for media in product.selected_product.media %}
                            <div class="swiper-slide rounded-[12px]">
                                {% if media.provider == 'youtube' %}
                                    {# extract video ID #}
                                    {% if 'watch?v=' in media.link %}
                                        {% set video_id = media.link | split('watch?v=') | last %}
                                    {% elif 'youtu.be/' in media.link %}
                                        {% set video_id = media.link | split('youtu.be/') | last %}
                                    {% elif 'shorts/' in media.link %}
                                        {% set video_id = media.link | split('shorts/') | last %}
                                    {% else %}
                                        {% set video_id = '' %}
                                    {% endif %}

                                    {# YouTube thumbnail #}
                                    <img
                                        src="https://img.youtube.com/vi/{{ video_id }}/hqdefault.jpg"
                                        alt="YouTube video thumbnail"
                                        width="200" height="200"
                                        class="block w-full h-full object-cover sm:object-contain sm:rounded-[12px]"
                                    >

                                    {# Optional play icon overlay #}
                                    <div class="absolute inset-0 flex items-center justify-center">
                                        <svg class="w-10 h-10 text-white bg-black/60 rounded-full p-2" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M6 4l12 6-12 6V4z" />
                                        </svg>
                                    </div>
                                {% else %}
                                    <img
                                        src="{{ image_url(media.image.full_size, w=200, f='auto') }}"
                                        alt="{{ media.image.alt }}"
                                        width="200" height="200"
                                        class="block w-full h-full object-cover sm:object-contain sm:rounded-[12px]"
                                    >
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>

                </div>

  
                <!-- No image -->
                <div class="no-image {% if product.selected_product.images | length > 0 %}hidden{% endif %}">
                    <img src="{{ 'product-img.svg' | asset_url }}" width="100%" height="auto" />
                </div>
                {# product is out of stock #}
                    <div class=" flex w-full self-center justify-center {% if product.selected_product.out_of_stock %}block{% else %}hidden{% endif %} notify-text">
                    <div class="bg-red-600 text-white px-6 py-4 rounded-lg shadow-lg text-center">
                            <span class="notify-text text-sm font-semibold">المنتج غير متوفر</span>
                        </div>
                    </div>
                {# product share #}
                <div class="flex gap-3">
                
                  {% include "components/product_share.jinja" %}
                 {% set in_wishlist = customer.wishlist is defined and product.id in customer.wishlist %}
                        {% if customer %}
                            <button onclick="addToWishlist(this, '{{ product.id }}',event)" type="button" class="{% if in_wishlist %}filled{% endif %}">
                                <svg width="25" class="stroke-red-700 {% if in_wishlist %}fill-red-700{% endif %}" height="25" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M31.55 52.025C30.7 52.325 29.3 52.325 28.45 52.025C21.2 49.55 5 39.225 5 21.7249C5 13.9999 11.225 7.74994 18.9 7.74994C23.45 7.74994 27.475 9.94994 30 13.3499C32.525 9.94994 36.575 7.74994 41.1 7.74994C48.775 7.74994 55 13.9999 55 21.7249C55 39.225 38.8 49.55 31.55 52.025Z" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span class="loading loading-spinner loading-xs loader hidden"></span>
                            </button>
                        {% else %}
                            <button onclick="alertMessage('{{ _("You need to log in first") }}', 'info')" type="button">
                            <svg width="25" class="stroke-red-700" height="25" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M31.55 52.025C30.7 52.325 29.3 52.325 28.45 52.025C21.2 49.55 5 39.225 5 21.7249C5 13.9999 11.225 7.74994 18.9 7.74994C23.45 7.74994 27.475 9.94994 30 13.3499C32.525 9.94994 36.575 7.74994 41.1 7.74994C48.775 7.74994 55 13.9999 55 21.7249C55 39.225 38.8 49.55 31.55 52.025Z" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span class="loading loading-spinner loading-xs loader hidden"></span>
                            </button>
                        {% endif %} 
                </div>
                
            </div>       

            {# info #}
            <div class="flex flex-col sm:col-span-3">
                <div class="flex justify-between items-center">
                  <h1 class="font-bold text-xl sm:text-2xl leading-7">{{ product.name }}</h1>
                  <div class="flex gap-2">
                       
                        {% if product.badge.body.ar %}
                        <div class="badge badge-outline text-xs sm:text-sm whitespace-nowrap">{{ product.badge.body.ar }}</div>
                        {% endif %}

                   </div>
                </div>
                <div class="sku flex gap-1 text-[#64748b] mt-3 sm:mt-5 items-center {% if not product.selected_product.sku %}hidden{% endif %}">
                    <span class="text-[16px]">{{ _("product code") }}:</span>
                    <span class="sku_text text-[14px] self-end">{{ product.selected_product.sku }}</span>
                </div>
                <div class="flex items-center gap-3 mt-3 sm:mt-5 section-formated-sale {% if product.selected_product.formatted_sale_price %}block{% else %}hidden{% endif %}">
                    <span class="line-through text-lg text-neutral-content product-formatted-price">{{ product.selected_product.formatted_price }}</span>
                    <span class="text-red-700 font-bold text-2xl product-formatted-sale-price">{{ product.selected_product.formatted_sale_price }}</span>
                    <span class="badge badge-error product-discount"> &nbsp;  &nbsp;{{ _("Discount") }}&nbsp;{{ product.selected_product.discount_percentage }}%</span>
                </div>
                
                <div class="text-base-content font-bold text-2xl mt-3 sm:mt-5 section-price {% if  product.selected_product.formatted_sale_price %}hidden{% else %}block{% endif %}">
                    <span class="product-formatted-price-old">{{  product.selected_product.formatted_price }}</span>
                </div>
                {# fake views #}
                <div class="containerCountFake mt-3 sm:mt-5">
                    <div class="views-counter">
                        <div class="particles-container" id="particles-container"></div>

                        <div class="icon-container">
                        <div class="icon-bg"></div>
                        <svg class="views-icon" viewBox="0 0 24 24" fill="currentColor">
                            <path
                            d="M12 5c-7 0-11 7-11 7s4 7 11 7 11-7 11-7-4-7-11-7zm0 11a4 4 0 110-8 4 4 0 010 8z"
                            />
                        </svg>
                        </div>

                        <div class="counter-content">
                        <div class="counter-display">
                            <span id="views-count">0</span>
                            <span class="counter-label">شاهدوا المنتج</span>
                        </div>
                        <div class="progress-container">
                            <div class="progress-info">
                            <span>0</span>
                            <span id="progress-percentage">0%</span>
                            <span>100</span>
                            </div>
                            <div class="progress-bar-container">
                            <div id="views-bar"></div>
                            </div>
                        </div>
                        </div>
                    </div>
                    </div>
                  <div class="section-notify-me  gap-3 {% if product.selected_product.out_of_stock %}block{% else %}hidden{% endif %}">
                    <div class="divider">{{ _("Notify me when the product is available") }}</div>
                    <form class="flex flex-col gap-3" id="notify-me-form">
                       <label class="input input-bordered flex items-center gap-2">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 16 16"
                                fill="currentColor"
                                class="h-4 w-4 opacity-70">
                                <path
                                d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM12.735 14c.618 0 1.093-.561.872-1.139a6.002 6.002 0 0 0-11.215 0c-.22.578.254 1.139.872 1.139h9.47Z" />
                            </svg>
                            <input type="text" class="grow" placeholder="{{ _("Name") }}" name="customerName"/>
                        </label>
                        <label class="input input-bordered flex items-center gap-2">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 16 16"
                                fill="currentColor"
                                class="h-4 w-4 opacity-70">
                                <path
                                d="M2.5 3A1.5 1.5 0 0 0 1 4.5v.793c.026.009.051.02.076.032L7.674 8.51c.206.1.446.1.652 0l6.598-3.185A.755.755 0 0 1 15 5.293V4.5A1.5 1.5 0 0 0 13.5 3h-11Z" />
                                <path
                                d="M15 6.954 8.978 9.86a2.25 2.25 0 0 1-1.956 0L1 6.954V11.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V6.954Z" />
                            </svg>
                            <input type="email" class="grow" placeholder="{{ _("Email") }}" name="email" required  />
                        </label>
                       
                        <div>
                            <label class="input input-bordered flex items-center gap-2">
                                <input type="number" class="grow" placeholder="{{ _("Mobile Number") }}" name="customerPhoneNumber" />
                                <span class="badge badge-info">{{ _("Optional") }}</span>
                            </label>
                            <p class="text-base-content  text-sm mt-2">{{ _("Example: 966500112245") }}</p>
                        </div>
                        <button  class="btn btn-primary relative" type="submit">
                            {{ _("Send") }}
                            <span class="loading loading-infinity loading-sm hidden absolute left-[15px] top-1/2 -translate-y-1/2"></span>
                        </button>
                    </form>
                </div>
                  <div class="mt-3 sm:mt-5">
                                        {% include 'vitrin:products/loyalty_points_widget.jinja' %}
                </div>
                <div class="mt-3 sm:mt-5">
                    {% include 'vitrin:products/payment_widgets.jinja' %}
                </div>
          
          

                
                {# <p class="weight mt-3 sm:mt-5 text-sm font-bold {% if product.selected_product.weight.value  %} block{% else %} hidden{% endif %}">{{ product.selected_product.weight.value }} {{ product.selected_product.weight.unit }} </p> #}
              

                {% if product.sold_products_count %}
                <div class="text-sm lg:text-lg">
                  {{ _("Sold Over") }}
                  <span class="text-primary">{{  product.sold_products_count }}</span>
                  {{ _("once") }}
                </div>
                {% endif %}
                {% if product.selected_product.formatted_sale_price %}
                    {% if product.purchase_restrictions.sale_price_period_end %}
                        <div id="countdownProductPage" class="flex flex-wrap justify-center lg:justify-start gap-5 mt-3 sm:mt-5">
                            <div class="bg-base-200 rounded-box text-base-content flex flex-col p-2">
                                <span class="countdown font-mono text-2xl">
                                <span class="countdown-days" style="--value:0;"></span>
                                </span>
                                {{ _("Day") }}
                            </div>
                            <div class="bg-base-200 rounded-box text-base-content flex flex-col p-2 ">
                                <span class="countdown font-mono text-2xl">
                                <span class="countdown-hours" style="--value:0;"></span>
                                </span>
                                {{ _("Hour") }}
                            </div>
                            <div class="bg-base-200 rounded-box text-base-content flex flex-col p-2">
                                <span class="countdown font-mono text-2xl">
                                <span class="countdown-minutes" style="--value:0;"></span>
                                </span>
                                {{ _("Minute") }}
                            </div>
                            <div class="bg-base-200 rounded-box text-base-content flex flex-col p-2">
                                <span class="countdown font-mono text-2xl">
                                <span class="countdown-seconds" style="--value:0;"></span>
                                </span>
                                {{ _("Second") }}
                            </div>
                        </div>
                    {% endif %}
                    
                {% endif %}
                <form id="product-form" id="userForm">
                        <input id="product-id" type="hidden" value="{{ product.selected_product.id }}">

                        <div class="size-box mb-4">
                            
                                <div class="hidden">
                                  {% include 'vitrin:products/variants_list.jinja' %}
                                </div>

                                {% if product.has_options %}
                                   <div class="custom_variants flex flex-col ">
                                   </div>
                                   {# {% for index, option in product.options %} 
                                        {% if (option.name | trim | lower) in 'color'or (option.name | trim | lower) in 'Color' or (option.name | trim) in 'اللون' %}             
                                            <div class="variants-options flex items-center gap-3 mt-3 sm:mt-5">
                                                <span class="text-sm sm:text-base font-bold">{{ option.name }}:</span>
                                                {% for choice in option.choices %}
                                                <div onclick="globalVariantClicked(event)"
                                                data-value="{{ choice }}" data-name="{{ option.name }}" class="attribute color-attribute  color-variant w-[30px] h-[30px] rounded-full cursor-pointer {% if product.selected_product.attributes[index].value == choice %} active {% endif %}" {% set color_parts = choice | split('-') %}style="background-color:{{ color_parts[1] if color_parts | length > 1 else choice }}"></div>
                                                {% endfor %}
                                            </div>
                                        {% else %}
                                             <div class="variants-options flex items-center gap-3 mt-3 sm:mt-5">         
                                                <span class="text-sm sm:text-base font-bold">{{ option.name }}:</span>   
                                               {% for choice in option.choices %}                                  
                                                <div  onclick="globalVariantClicked(event)" class="attribute global-attribute global-variant min-w-[60px] min-h-[40px] rounded-lg text-base sm:text-lg text-base-content bg-base-100 flex items-center justify-center font-bold cursor-pointer  {% if product.selected_product.attributes[index].value == choice %} active {% endif %}" data-value="{{ choice }}" data-name="{{ option.name }}">
                                                    {{ choice }}
                                                </div>
                                                {% endfor %}
                                            </div>
                                        {% endif %} 
                                    {% endfor %} #}
                                {% endif %}
                                {% if product.has_custom_input_fields  %}
                                    <div class="zid_custom_input_fields mt-3 sm:mt-5 flex flex-col gap-2">
                                      {% include 'vitrin:products/custom_input_fields.jinja' %}
                                    </div>
                                {% endif %}
                 
                        </div>

                </form>
                <div class="payment_methods flex flex-wrap justify-center items-center gap-3 border border-[#e1e1e1] rounded-md p-3 w-full">
                   
                    {% for payment_method in store.settings.checkout.payment_methods %}
                        <div  aria-label="payment method">
                            <img src="{{ image_url(payment_method.icon, h=26, q=100) }}"  alt="" width="36"  alt='payments' class="max-w-[40px] max-h-[40px] object-cover">
                        </div>
                    {% endfor %}
                </div>
                <div class="mt-3 sm:mt-5">
                    {% include 'vitrin:checkout/apple-pay-quick-checkout.jinja' %}
                </div>
              
            
            </div>
            {# info #}

      </div>

      {# reviews and questions #}
      <section class="tab-content bg-base-100 border-base-300 rounded-box p-6  flex flex-col gap-5 sm:gap-8 mt-5 sm:mt-8" >
          
                {% if product.short_description %}
                    <div class="mt-3 sm:mt-5 font-light text-base text-center sm:text-lg">
                        <h3 class=" text-base sm:text-lg font-bold  mb-3">{{ _("Product Overview") }}</h3>
                        {{ product.short_description | safe }}
                    </div>
                {% endif %}
            {% if product.description and product.description|striptags|trim|length > 0 %}
    <div class="flex flex-col gap-3">
        <h3 class="tab whitespace-nowrap text-base sm:text-lg font-bold text-center">
            {{ _("Product Details") }}
        </h3>

        <div 
            id="productDescription" 
            class="font-light text-lg leading-8 text-base-content text-center max-w-full sm:max-w-[700px] m-auto line-clamp-3 overflow-hidden"
        >
            {{ product.description | safe }}
        </div>

        <button 
            id="toggleDescription" 
            class="text-primary text-sm font-medium underline mx-auto mt-2 hidden"
        >
            إظهار المزيد
        </button>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const desc = document.getElementById("productDescription");
            const btn = document.getElementById("toggleDescription");

            // check if content exceeds 3 lines
            if (desc.scrollHeight > desc.clientHeight) {
                btn.classList.remove("hidden");
            }

            btn.addEventListener("click", function () {
                if (desc.classList.contains("line-clamp-3")) {
                    desc.classList.remove("line-clamp-3", "overflow-hidden");
                    btn.textContent = "إظهار أقل";
                } else {
                    desc.classList.add("line-clamp-3", "overflow-hidden");
                    btn.textContent = "إظهار المزيد";
                }
            });
        });
    </script>
{% endif %}
            {# reviews #}
            {% if product.rating %} 
                <div class="flex flex-col items-center gap-3">
                    <h3 class="tab whitespace-nowrap text-base sm:text-lg font-bold text-center">{{ _("Reviews") }}</h3>                
                    <span class="font-mono text-6xl">{{ product.rating.average }}</span>
                    {% set rating = product.rating.average %}{% set sizeSvg = 30 %}
                    {% include 'components/rating-stars.jinja' %}
                </div>

            {% else %}    
            {# <div class="flex flex-col items-center gap-3"> #}
                {# <h2>0.0</h2>
                <div class="flex gap-2">
                        <svg width="30" height="30" viewBox="0 0 68 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M34 0L41.858 24.1844L67.287 24.1844L46.7145 39.1312L54.5725 63.3156L34 48.3688L13.4275 63.3156L21.2855 39.1312L0.71302 24.1844L26.142 24.1844L34 0Z" fill="#e3e3e3"/>
                        </svg>
                        <svg width="30" height="30" viewBox="0 0 68 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M34 0L41.858 24.1844L67.287 24.1844L46.7145 39.1312L54.5725 63.3156L34 48.3688L13.4275 63.3156L21.2855 39.1312L0.71302 24.1844L26.142 24.1844L34 0Z" fill="#e3e3e3"/>
                        </svg>
                        <svg width="30" height="30" viewBox="0 0 68 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M34 0L41.858 24.1844L67.287 24.1844L46.7145 39.1312L54.5725 63.3156L34 48.3688L13.4275 63.3156L21.2855 39.1312L0.71302 24.1844L26.142 24.1844L34 0Z" fill="#e3e3e3"/>
                        </svg>
                        <svg width="30" height="30" viewBox="0 0 68 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M34 0L41.858 24.1844L67.287 24.1844L46.7145 39.1312L54.5725 63.3156L34 48.3688L13.4275 63.3156L21.2855 39.1312L0.71302 24.1844L26.142 24.1844L34 0Z" fill="#e3e3e3"/>
                        </svg>
                        <svg width="30" height="30" viewBox="0 0 68 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M34 0L41.858 24.1844L67.287 24.1844L46.7145 39.1312L54.5725 63.3156L34 48.3688L13.4275 63.3156L21.2855 39.1312L0.71302 24.1844L26.142 24.1844L34 0Z" fill="#e3e3e3"/>
                        </svg>
                        
                    </div> #}
            {# </div> #}
            {% endif %}
            {# all reviews #}
            {% if store.settings.products.reviews_enabled %}            
                {% set reviews = product.reviews.results %}
                {% include "components/product_reviews.jinja" %}
                {% include "components/product_add_review.jinja" %}
            {% endif %}
            
            {# questions #}
            {% if store.settings.products.questions_enabled %}            
                {% set questions = product.questions %}
                {% include "components/product_questions.jinja" %}
                {% include "components/product_add_question.jinja" %}
            {% endif %}
            

      </section>
      
        {% if (product.related_products | length) >  0 %}
         <div class="related_products mt-5 sm:mt-10">
            <div class="flex justify-between items-center gap-3 mb-5">
                <h2 class="title text-[25px] sm:text-[32px] font-bold">{{ _("Similar Products") }}</h2>
