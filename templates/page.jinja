{% extends "layout.jinja" %}

{% block title %} {{ store.name }} - {{ page.global.home }} {% endblock %}


{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block main_content %}
    <section class="blog mt-5 mb-5 text-center ">
        <div class="container">

            <div class="blog-title mt-5 mb-5 ">
                <h1>
                    {{ page.title }}
                </h1>
            </div>
            <div class="blog-text mt-3 mb-5 flex flex-col">
                {{ page.content | safe }}
            </div>


        </div>
    </section>

{% endblock %}

{% block footer %} {% include 'footer.jinja' %} {% endblock %}
