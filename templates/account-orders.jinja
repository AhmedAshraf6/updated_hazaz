{% extends "layout.jinja" %}

{% block title %} {{ store.name }} - {{ _("Orders") }} {% endblock %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block main_content %}
    {% set breadcrumbs = [
        { label: _("Home"), url: '/' },
        { label: _("Orders") }
    ] %}
    {% include 'components/breadcrumbs.jinja' %}

    <div class="my-5 layout orders_page">
       <div class="grid grid-cols-1 lg:grid-cols-4 mt-5 sm:mt-8 gap-3 sm:gap-5">
         <div class="col-span-1">
           {% include "components/profile_section_dropdown.jinja" %}
         </div>
         <div class="col-span-3">
           {% if orders|length > 0 %}
            <div class="flex gap-2">
                <div class="divider divider-horizontal divider-start m-0 w-auto"></div>
                <h1 class="text-lg sm:text-xl font-bold">{{ _("Orders") }}</h1>
            </div>
            <div class="overflow-x-auto mt-3 sm:mt-5">
                <table class="table">
                    <thead>
                        <tr>
                            <th>{{ _("Order") }}</th>
                            <th>{{ _("Status") }}</th>
                            <th>{{ _("Date") }}</th>
                            <th>{{ _("Total") }}</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for order in orders %}
                        <tr>
                            <th><a class="text-secondary underline" href="/orders/{{ order.code }}/invoice">#{{ order.id }}</a></th>
                            <td>{{ order.order_status.name }}</td>
                            <td>{{ datetimeFormat(order.created_at, 'd-m-Y g:i:s A', session.lang.code) }}</td>
                            <td>{{ order.order_total_string }}</td>
                            <td><a href="/orders/{{ order.code }}/invoice" class="btn btn-primary !px-[5px]">{{ _("View") }}</a></td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
           {% else %}
            <div class="flex flex-col gap-5 items-center justify-center">
              <div class="w-full max-w-lg">
                   <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" viewBox="0 0 885.55805 557.51874" xmlns:xlink="http://www.w3.org/1999/xlink" role="img"><path d="M838.81222,592.35166C875.238,501.28427,864.21905,399.5975,817.23963,321.5L325.46637,389.59166l471.2759-98.21687c-198.62291-247.68466-585.21339-83.39849-547.948,229.321Z" transform="translate(-157.22097 -171.24063)" fill="#e6e6e6"/><rect x="76.75322" y="320.44454" width="626.52594" height="195.09542" fill="#6c63ff"/></svg>
              </div>
              <p>{{ _("No orders yet") }}</p>
              <a href="/products" class="btn btn-outline !px-[10px]">{{ _("Shop Now") }}</a>
            </div>
           {% endif %}
         </div>
       </div>
    </div>

{% endblock %}

{% block footer %} {% include 'footer.jinja' %} {% endblock %}
