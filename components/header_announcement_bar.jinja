
{% if ab_settings.announcement_bar_display %}
    {% if not ab_settings.announcement_bar_page_display
        or (template == 'home' and ab_settings.announcement_bar_page_display == 'home')
        or ab_settings.announcement_bar_page_display == 'all'
    %}

<div class="announcement-bar" style="z-index: 4; {% if ab_settings.announcement_bar_background_color %}background: {{ ab_settings.announcement_bar_background_color }} {% endif %}">
    <div class="container flex justify-between relative layout">
        <a href="{{ ab_settings.announcement_bar_url }}" class="text-center flex justify-center w-full py-2">
            <h1 class="announcement-text mb-0 text-center" style="{% if ab_settings.announcement_bar_text_color %}color: {{ ab_settings.announcement_bar_text_color }}{% endif %}">
                {{ ab_settings.announcement_bar_text }}
            </h1>
        </a>
        <button class="close" type="button" onclick="hideAnnouncementBar()">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </button>
    </div>
</div>

    {% endif %}
{% endif %}
