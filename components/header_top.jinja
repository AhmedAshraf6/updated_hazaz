      {% if not ('hide_country' in ab_settings.header_options) %}
          <button type="button" class="flex items-center gap-3 cursor-pointer  " onclick="currencyModal.showModal()">
            <img class="w-[20px] h-[20px] object-contain current_flag" src="{{ session.country.flag }}" alt="{{ session.country.code }}">
            <span class="currency current_currency">
                {{ session.currency.symbol }}
            </span>
          </button>
        {% set id = "currencyModal" %}
        {% include 'components/header_curreny_modal.jinja' %}
      {% endif %}
    </div> #}
   {# logo #}
    <a href="/" class="logo ">
        {% if ab_settings.header_logo %}
            {% set logoUrl = ab_settings.header_logo %}
        {% else %}
            {% set logoUrl = store.settings.branding.logo %}
        {% endif %}

        {% if ab_settings.header_logo_mobile %}
            {% set logoUrlMobile = ab_settings.header_logo_mobile %}
        {% else %}
            {% set logoUrlMobile = store.settings.branding.logo %}
        {% endif %}

        <img class="hidden md:block w-[180px] h-[55px] object-contain" src="{{ image_url(logoUrl, h=175, q=85, f='auto') }}" alt="{{ store.name }}">

        <img class="block md:hidden w-[180px] h-[55px] object-contain" src="{{ image_url(logoUrlMobile, h=175, q=85, f='auto') }}" alt="{{ store.name }}">
    </a>
    {% if not ('hide_search_bar' in ab_settings.header_options) %}
      <div class="flex flex-col gap-2 relative search-container">
        <label class="input shadow-md flex items-center gap-2">
          <input type="text" class="grow lg:w-[680px] h-[70px]  search_input" id="searchInput" placeholder="{% if ab_settings.header_search_placeholder %} {{  ab_settings.header_search_placeholder }} {% else %}{{  _("Search for products...") }}{% endif %}" />
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            
            class="h-[25px] w-[25px] opacity-70 fill-current ">
            <path
              fill-rule="evenodd"
              d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.755-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"
              clip-rule="evenodd" />
          </svg>
        </label>
        <div class="result_search_box w-full  absolute top-[49px] bg-base-200 h-max p-4 z-[1] hidden">
          <span class="loading loading-dots loading-lg  search_loading block mx-auto "></span>
          <div class="result_search flex flex-wrap gap-3">
          </div>
          <div class="search_more_btn hidden mt-3">
            <div class="flex justify-center">
                <a href="/products?search=" class="btn btn-primary !px-[20px]">للمزيد</a>
            </div>
          </div>
        </div>
      </div>
    {% endif %}


    <div class="flex gap-3">
     {% if not ('hide_darkMode' in ab_settings.header_options) %}
        {# Dark and Light mode #}
        {% include 'components/header_dark_mode.jinja' %}
      {% endif %}
     {% if not ('hide_favourite' in ab_settings.header_options) %}
        <a type="button" class="fav_icon" href="{% if customer %}/account-wishlist{% else %}/auth/login{% endif %}">
          <svg class="stroke-current" width="25" height="25" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M43.4168 9.60429C42.3526 8.53971 41.0893 7.69524 39.6988 7.11906C38.3081 6.54289 36.8178 6.24634 35.3126 6.24634C33.8073 6.24634 32.3171 6.54289 30.9263 7.11906C29.5358 7.69524 28.2726 8.53971 27.2083 9.60429L25.0001 11.8126L22.7917 9.60429C20.6424 7.45494 17.7272 6.24744 14.6876 6.24744C11.6479 6.24744 8.73276 7.45494 6.58341 9.60429C4.43406 11.7537 3.22656 14.6688 3.22656 17.7085C3.22656 20.7481 4.43406 23.6633 6.58341 25.8127L8.79174 28.021L25.0001 44.2292L41.2083 28.021L43.4168 25.8127C44.4813 24.7486 45.3258 23.4852 45.9021 22.0946C46.4781 20.7041 46.7748 19.2136 46.7748 17.7085C46.7748 16.2033 46.4781 14.7128 45.9021 13.3223C45.3258 11.9318 44.4813 10.6684 43.4168 9.60429Z"  stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
        <div class="flex items-center gap-3 " id="drawerDesktop">

      
          <div class="drawer drawer-end w-max z-[2]">
              {# <input id="my-drawer-mini-cart" type="checkbox" class="drawer-toggle" /> #}
              <a href="/cart/view" class="drawer-content">
                <!-- Page content here -->
                <label for="my-drawer-mini-cart" class="drawer-button cart_icon relative cursor-pointer    group-[.slidedown]:text-base-content">
                      <svg class="stroke-current" width="25" height="25" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M17.5 13.5417H32.5001C39.5834 13.5417 40.2917 16.8542 40.7709 20.8958L42.6459 36.5208C43.2501 41.6458 41.6667 45.8333 34.3751 45.8333H15.6459C8.33338 45.8333 6.75005 41.6458 7.37505 36.5208L9.25007 20.8958C9.7084 16.8542 10.4167 13.5417 17.5 13.5417Z"  stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M16.667 16.6667V9.37499C16.667 6.24999 18.7503 4.16666 21.8753 4.16666H28.1253C31.2503 4.16666 33.3337 6.24999 33.3337 9.37499V16.6667"  stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="w-[20px] h-[20px] rounded-full bg-primary text-secondary  flex justify-center items-center hidden absolute -top-1 -right-2 badge_cart_icon font-mono"></span>
                </label>
              </a>
              <div class="drawer-side">
                <label for="my-drawer-mini-cart" aria-label="close sidebar" class="drawer-overlay"></label>
                <ul class="menu bg-base-200 text-base-content min-h-full w-96  h-full">
                  {% include "components/mini_cart.jinja" %}
                </ul>
              </div>
          </div>
   
       </div>
   
      {% if customer %}
        <div class="dropdown dropdown-hover">
            <div tabindex="0" role="button" class="flex gap-2 items-center    group-[.slidedown]:text-base-content">
                <div class="icon">
                    <svg class="stroke-current" width="25" height="25" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M20 21V19C20 17.9391 19.5786 16.9217 18.8284 16.1716C18.0783 15.4214 17.0609 15 16 15H8C6.93913 15 5.92172 15.4214 5.17157 16.1716C4.42143 16.9217 4 17.9391 4 19V21"  stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                                      <path d="M12 11C14.2091 11 16 9.20914 16 7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7C8 9.20914 9.79086 11 12 11Z"  stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>   
                </div>
                <span class="line-clamp-1">{{ customer.name }}</span>
            </div>
            <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-[1] w-52 p-2 shadow">
              <li>
                <a class="flex items-center gap-2" href="/account-profile">
                    <svg class="stroke-current" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M20 21V19C20 17.9391 19.5786 16.9217 18.8284 16.1716C18.0783 15.4214 17.0609 15 16 15H8C6.93913 15 5.92172 15.4214 5.17157 16.1716C4.42143 16.9217 4 17.9391 4 19V21"  stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                                      <path d="M12 11C14.2091 11 16 9.20914 16 7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7C8 9.20914 9.79086 11 12 11Z"  stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>   
                  {{ _("Account Profile") }}
                </a>
              </li>
              <li >
                  <div class="flex items-center gap-2">     
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M9 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H9" stroke="#FF2020" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                          <path d="M16 17L21 12L16 7" stroke="#FF2020" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                          <path d="M21 12H9" stroke="#FF2020" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>   
                      <form action="/auth/logout" method="POST">
                          <input type="hidden" name="_token" value="{{ csrf_token }}">
                          <button type="submit" class="logout text-[#ff2020]">{{ _("Sign Out") }}</button>
                      </form>
                  </div>
              </li>
            </ul>
        </div>    
      {% else %}
        <button type="btton" onclick="window.location.href='/auth/login'" class="flex gap-3 items-center    group-[.slidedown]:text-base-content">
            <div class="icon">
                   <svg class="stroke-current" width="25" height="25" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M20 21V19C20 17.9391 19.5786 16.9217 18.8284 16.1716C18.0783 15.4214 17.0609 15 16 15H8C6.93913 15 5.92172 15.4214 5.17157 16.1716C4.42143 16.9217 4 17.9391 4 19V21"  stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                                    <path d="M12 11C14.2091 11 16 9.20914 16 7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7C8 9.20914 9.79086 11 12 11Z"  stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                   </svg>   
            </div>
            <span>
            {{ _("Login") }}
            </span>
        </button>
      {% endif %}
     
      
    </div>

