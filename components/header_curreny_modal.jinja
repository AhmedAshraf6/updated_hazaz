<dialog id="{{ id }}" class="modal">
  <div class="modal-box">

    <div class="flex justify-between items-center gap-3">
      <h3>{{ _("Country") }}</h3>
      <div class="modal-action">
        <form method="dialog">
          <!-- if there is a button in form, it will close the modal -->
          <button > 
                  <svg class="stroke-current" width="25" height="25" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M24.9994 45.8333C36.4577 45.8333 45.8327 36.4583 45.8327 25C45.8327 13.5417 36.4577 4.16667 24.9994 4.16667C13.541 4.16667 4.16602 13.5417 4.16602 25C4.16602 36.4583 13.541 45.8333 24.9994 45.8333Z"  stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M19.1035 30.8958L30.8952 19.1042"  stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M30.8952 30.8958L19.1035 19.1042"  stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
           </button>
        </form>
      </div>
    </div>

   <div class="flex flex-col gap-[30px] mt-[20px] max-h-[300px] overflow-auto all_currencies">
     {% for currency in store.currencies %}
       <div class="flex justify-between items-center currency_box gap-2 cursor-pointer  border-b-[1px] border-base-200 pb-[20px] {% if currency.country.code == session.country.code  %} active {% endif %}" data-code="{{ currency.code }}" data-countrycode="{{ currency.country.code }}" data-symbol="{{ currency.symbol }}" data-flag="{{ currency.country.flag }}">
         <div class="flex gap-4">
             <img class="w-[20px] h-[20px] object-contain" src="{{ currency.country.flag }}" alt="{{ currency.country.code }}">
             <span>{{ currency.country.name }}</span>
         </div>
          <svg width="20" height="20" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="{% if currency.country.code != session.country.code  %} hidden {% endif %} stroke-current">
          <path d="M33.3327 10L14.9993 28.3333L6.66602 20" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
         
       </div>
     {% endfor %}
    
   </div>
   
   <div class="flex w-full justify-center mt-3">
     <button type="button" class="btn  bg-primary text-base-100 rounded-full btn-wide save_currency ">{{ _("Save") }}</button>
   </div>

  </div>
</dialog>
