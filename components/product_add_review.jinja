  </div>
</dialog>
<script>
    let selectedImages = [];
    // Trigger the hidden file input when the custom image is clicked
    document.getElementById('custom-file-trigger').addEventListener('click', function() {
        document.getElementById('review_images').click();
    });
    
    function submitReview() {
    const loadingIndicator = document.querySelector('.add-rate-section .add-review-progress');
    const commentInput = document.querySelector('.add-rate-section .input-review-comment');
    const ratingInput = document.querySelector('input[name="rating-form-product"]:checked').value;
    const isAnonymousCheckbox = document.querySelector('.add-rate-section .is_review_customer_anonymous');
    const files = selectedImages; // Use the updated selectedImages array

    // Check if progress indicator is not hidden
    if (!loadingIndicator.classList.contains('hidden')) {
        return;
    }


    // Check if more than 3 images are selected
    if (files.length > 3) {
        alertMessage('{{ _("You have exceeded the allowed image limit (3 images). Please remove one image to proceed. Supported formats: png, jpg, jpeg, gif.") }}','error');
        return;
    }
    if (commentInput.value.length > 250) {
        alertMessage('{{ _("Maximum character limit is 250") }}','error');
        return;
    }

    // Prepare FormData
    const formData = new FormData();
    formData.append('comment', commentInput.value);
    formData.append('rating', parseInt(ratingInput, 10));  // Ensure rating is parsed as an integer
    formData.append('is_anonymous', isAnonymousCheckbox.checked);

    // Append files to FormData
    for (let i = 0; i < files.length; i++) {
        formData.append(`images[${i}][file]`, files[i]);
    }

    sendReview(formData);

    async function sendReview(data) {
        // Show the loading overlay
        loadingIndicator.classList.remove('hidden');

        try {
            const response = await fetch(`/api/v1/reviews/products/{{ product.id }}/submit`, {
                method: 'POST',
                body: data,  // Send FormData directly without JSON.stringify
            });

            if (!response.ok) {
                const errorText = await response.text();
                alertMessage(errorText, 'error');
            }

            const responseData = await response.json();
            if (responseData.status === 'success') {
                alertMessage('{{ _("Successfully sent") }}', 'success');
            } else {
                alertMessage(responseData.data.message, 'error');
            }
        } catch (error) {
            alertMessage(localsLayout.error, 'error');
        } finally {
            loadingIndicator.classList.add('hidden');
            commentInput.value = '';
            isAnonymousCheckbox.checked = false;
            selectedImages = [];
            document.getElementById('image_preview').innerHTML = '';

        }
    }
}



    function updateImagePreview() {
        const previewContainer = document.getElementById('image_preview');
        previewContainer.classList.remove('hidden');
        previewContainer.innerHTML = '';

        // Loop through the updated selectedImages array and re-render previews
        if (selectedImages.length <= 0 ) {
            previewContainer.classList.add('hidden');
         } 
        selectedImages.forEach((file, index) => {
            const reader = new FileReader();

            reader.onload = function (e) {
                const imgElement = document.createElement('div');
                imgElement.classList.add('relative', 'image-preview-container', 'border', 'rounded', 'p-1', 'shadow-sm');
                imgElement.innerHTML = `
                    <div class="relative">
                        <img src="${e.target.result}" class="w-[120px] h-[120px] object-contain" alt="Image Preview">
                        <span class="absolute top-0 text-error" >
                                   <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current remove-image cursor-pointer " fill="none" viewBox="0 0 24 24" data-index="${index}">
                                      <path
                                       stroke-linecap="round"
                                       stroke-linejoin="round"
                                       stroke-width="2"
                                       d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" 
                                       />
                                    </svg>
                        </span>
                    </div>
                `;
                previewContainer.appendChild(imgElement);
            };

            reader.readAsDataURL(file); // Read file as URL to display it as an image
        });

        // Update validation and disable submit button if more than 3 images are selected
        const submitButton = document.querySelector('.add-rate-section .add-review-btn');

        if (selectedImages.length > 3) {
            alertMessage('{{ _("You have exceeded the allowed image limit (3 images). Please remove one image to proceed. Supported formats: png, jpg, jpeg, gif.") }}','error');
            submitButton.disabled = true;
            submitButton.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            submitButton.disabled = false;
            submitButton.classList.remove('opacity-50', 'cursor-not-allowed');
        }
    }
     document.addEventListener("DOMContentLoaded", function(){
        
          document.getElementById('review_images').addEventListener('change', function() {
                const files = Array.from(this.files); // Convert FileList to Array
                const previewContainer = document.getElementById('image_preview');

                // Clear previous previews
                previewContainer.classList.remove('hidden');
                previewContainer.innerHTML = '';
                selectedImages = files; // Update the selectedImages array with current files

                // If more than 3 images are selected, show warning and disable submit
                if (selectedImages.length > 3) {
                    alertMessage('{{ _("You have exceeded the allowed image limit (3 images). Please remove one image to proceed. Supported formats: png, jpg, jpeg, gif.") }}','error');
                    document.querySelector('.add-rate-section .add-review-btn').disabled = true;
                    return;
                } else {
                    document.querySelector('.add-rate-section .add-review-btn').disabled = false;
                }

                // Loop through the selected files and create a preview with remove buttons
                selectedImages.forEach((file, index) => {
                    const reader = new FileReader();
                    
                    reader.onload = function(e) {
                        const imgElement = document.createElement('div');
                        imgElement.classList.add('relative', 'image-preview-container', 'border', 'rounded', 'p-1', 'shadow-sm');
                        imgElement.innerHTML = `
                            <div class="relative ">
                                <img src="${e.target.result}" class="img_thumbnail w-[120px] h-[120px] object-contain" alt="Image Preview">
                                <span class="absolute top-0 text-error" >
                                   <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current remove-image cursor-pointer " fill="none" viewBox="0 0 24 24" data-index="${index}">
                                      <path
                                       stroke-linecap="round"
                                       stroke-linejoin="round"
                                       stroke-width="2"
                                       d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" 
                                       />
                                    </svg>
                                </span>
                            </div>
                        `;
                        previewContainer.appendChild(imgElement);
                    }

                    reader.readAsDataURL(file); // Read file as URL to display it as an image
                });
        });
        // Handle image removal
        document.getElementById('image_preview').addEventListener('click', function(e) {
            if (e.target.classList.contains('remove-image')) {
                const indexToRemove = e.target.getAttribute('data-index');
                
                // Remove the image from the selectedImages array
                selectedImages.splice(indexToRemove, 1);

                // Trigger the change event again to update the UI and validation
                updateImagePreview();
            }
        });
       
    });


</script>