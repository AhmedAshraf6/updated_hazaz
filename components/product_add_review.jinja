                    </svg>
                    <p class="text-center">{{ _("Attach images with the comment") }}</p>
                </div>
              </div>
              <div id="image_preview" class="hidden flex  flex-wrap gap-3 images_preview_reviews  mt-3 sm:mt-5"></div>

          </div>
       </div>
       <button type="button" class="btn btn-primary relative add-review-btn"  onclick='submitReview()'>
           {{ _("Send") }}
           <span class="add-review-progress loading loading-infinity loading-sm hidden absolute left-[15px] top-1/2 -translate-y-1/2"></span>
       </button>     
