        <input type="radio" name="rating-form-product" value="3" class="mask mask-star-2 bg-[#f1c727]" />
        <input type="radio" name="rating-form-product" value="4" class="mask mask-star-2 bg-[#f1c727]" />
        <input type="radio" name="rating-form-product" value="5" class="mask mask-star-2 bg-[#f1c727]" />
      </div>

      <textarea placeholder="{{ _("Write your comment") }}" class="textarea textarea-bordered textarea-md w-full max-w-xs input-review-comment"></textarea>
      <div class="form-control">
          <label class="label cursor-pointer justify-start gap-2">
            <input type="checkbox"  class="checkbox is_review_customer_anonymous" />
            <span class="label-text">{{ _("Do not show my name in customer reviews") }}</span>
          </label>
       </div>
       {# add review #}
      <div tabindex="0" class="collapse  w-auto">
          <input type="checkbox" class="peer" />
          <div class="collapse-title  font-medium  p-0 m-0">{{ _("Attach images with the comment") }}؟</div>
          <div class="collapse-content p-0 m-0">  
